# Copy to .env.development.local when you're ready to use (it's gitignored).

# Database (Prisma 7 — used by the pg driver adapter + migrations). Optional; the
# template runs without a DB until you query one.
DATABASE_URL=

# Auth.js (Google provider). AUTH_SECRET is required for sessions.
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Sentry (optional — error/perf monitoring is dormant unless these are set).
# Server-side DSN:
SENTRY_DSN=
# Client-side DSN (exposed to the browser bundle; Vite requires the VITE_ prefix):
VITE_SENTRY_DSN=
# Source-map upload at build time (only needed for production releases):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
