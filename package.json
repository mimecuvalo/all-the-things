{
  "name": "all-the-things",
  "private": true,
  "description": "all the bells 🔔 and whistles 😙 for next.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/mimecuvalo/all-the-things.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.17.0"
  },
  "bugs": {
    "url": "https://github.com/mimecuvalo/all-the-things/issues"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "prisma generate && vite build",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "i18n:extract": "formatjs extract 'routes/**/*.ts*' 'components/**/*.ts*' --out-file i18n/en.json --additional-component-names F --id-interpolation-pattern '[md5:contenthash:hex:10]' --format smartling",
    "i18n:compile": "formatjs compile-folder i18n i18n/compiled --format smartling --ast",
    "alex": "alex .",
    "config": "node scripts/config.js",
    "prepare": "husky",
    "prisma:generate": "prisma generate",
    "test": "vitest",
    "test:ci": "vitest run",
    "type-check": "tsgo --noEmit"
  },
  "dependencies": {
    "@auth/core": "0.34.3",
    "@base-ui/react": "1.6.0",
    "@fontsource-variable/oswald": "5.2.8",
    "@hono/zod-validator": "0.8.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@sentry/tanstackstart-react": "10.63.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-start": "1.168.27",
    "classnames": "2.5.1",
    "hono": "4.12.27",
    "intl-messageformat": "11.2.9",
    "pg": "8.22.0",
    "prisma": "7.8.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-intl": "7.1.11",
    "sanitize.css": "13.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@formatjs/cli": "6.7.2",
    "@rolldown/plugin-babel": "0.2.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/babel__core": "7.20.5",
    "@types/node": "24.0.10",
    "@types/pg": "8.20.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "6.0.3",
    "alex": "11.0.1",
    "axe-core": "4.12.1",
    "babel-plugin-formatjs": "11.3.14",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "16.1.2",
    "nitro": "3.0.260610-beta",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "typescript": "5.8.3",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "oxfmt"
    ],
    "**/*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "bash -c 'bun run i18n:extract && bun run i18n:compile'"
    ],
    "prisma/schema.prisma": [
      "bun run prisma:generate"
    ]
  },
  "husky": {
    "hooks": {
      "post-checkout": "./scripts/post-checkout",
      "post-merge": "./scripts/post-merge"
    }
  },
  "browserslist": "last 2 versions",
  "sideEffects": false,
  "packageManager": "bun@1.3.2"
}
